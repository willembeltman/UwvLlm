<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UwvLlm.App.Core.ViewModels;assembly=UwvLlm.App.Core"
             x:Class="UwvLlm.App.Pages.RegisterPage"
             Title="Register">

    <VerticalStackLayout Padding="30" Spacing="20">

        <Label Text="Registreren" />

        <Entry Placeholder="Username"
               Text="{Binding UserName}" />

        <Entry Placeholder="Email"
               Text="{Binding Email}" />

        <Entry Placeholder="Wachtwoord"
               IsPassword="True"
               Text="{Binding Password}" />

        <Entry Placeholder="Wachtwoord"
               IsPassword="True"
               Text="{Binding PasswordRepeat}" />

        <Button Text="Registreren"
                Command="{Binding RegisterCommand}" />

        <Button Text="Ga naar login pagina"
                Command="{Binding GotoLoginCommand}" />

    </VerticalStackLayout>

</ContentPage>