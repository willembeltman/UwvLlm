<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UwvLlm.App.Core.ViewModels;assembly=UwvLlm.App.Core"
             x:Class="UwvLlm.App.Pages.NotificationsPage"
             Title="Notifications">

    <VerticalStackLayout Padding="10">

        <Label Text="{Binding NotificationCount, StringFormat='Notifications: {0}'}"
               FontSize="18" />

        <CollectionView ItemsSource="{Binding NotificationList}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="10">
                        <Label Text="{Binding Title}" />
                        <Label Text="{Binding Message}" FontSize="12" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Open notifications"
                Command="{Binding OpenNotificationsCommand}" />

    </VerticalStackLayout>
</ContentPage>