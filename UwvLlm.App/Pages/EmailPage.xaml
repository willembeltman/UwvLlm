<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UwvLlm.App.Core.ViewModels;assembly=UwvLlm.App.Core"
             x:Class="UwvLlm.App.Pages.EmailPage"
             Title="Email versturen">

    <Shell.TitleView>
        <Grid>
            <Label Text="Mijn App" HorizontalOptions="Start" />

            <Grid HorizontalOptions="End">
                <Image Source="bell.png" WidthRequest="24" HeightRequest="24" />

                <Border
                    BackgroundColor="Red"
                    Padding="2"
                    IsVisible="{Binding HasNotifications}"
                    HorizontalOptions="End"
                    VerticalOptions="Start">

                    <Label
                        Text="{Binding NotificationCount}"
                        FontSize="10"
                        TextColor="White" />
                </Border>
            </Grid>
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15">

            <Picker Title="Selecteer gebruiker"
                ItemsSource="{Binding Users}"
                ItemDisplayBinding="{Binding UserName}"
                SelectedItem="{Binding SelectedUser}" />
            
            <Entry Placeholder="Titel"
                   Text="{Binding Subject}" />

            <Editor Placeholder="Bericht..."
                    Text="{Binding Body}" />

            <Button Text="Verstuur"
                    Command="{Binding SendCommand}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>