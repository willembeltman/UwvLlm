      "Microsoft.AspNetCore.Http.Connections": "Warning",
      "Microsoft.AspNetCore.Server": "Warning",
      "Dinostamp": "Warning",
      "gAPI": "Warning"
    }
  },
  "AllowedHosts": "*"
